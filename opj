//  BUILD FICHES SECTION
// ══════════════════════════════════════════════════
let ficheMode='infractions';

function buildFiches(){
  // infractions
  $('infractionsContent').innerHTML=INFRACTIONS.map(inf=>`
    <div class="accordion-item" onclick="this.classList.toggle('open')" data-search="${(inf.title+' '+inf.resume+' '+inf.mnemo2).toLowerCase()}">
      <div class="accordion-head"><div class="accordion-title">${inf.title}</div><div class="accordion-arrow">▶</div></div>
      <div class="accordion-body">
        <p><em>${inf.resume}</em></p>
        <div class="elem-row">
          <div class="elem-block"><div class="elem-lbl">⚖️ Légal</div><div class="elem-txt">${inf.legal}</div></div>
          <div class="elem-block"><div class="elem-lbl">🔨 Matériel</div><div class="elem-txt">${inf.materiel}</div></div>
          <div class="elem-block"><div class="elem-lbl">🧠 Moral</div><div class="elem-txt">${inf.moral}</div></div>
        </div>
        <div class="mnemo-box"><div class="mnemo-lbl">🗝️ Astuce mémo</div><div class="mnemo-txt">${inf.mnemo}</div><div class="mnemo-sub">${inf.mnemo2}</div></div>
      </div>
    </div>`).join('');

  // fiches proc
  $('fichesContent').innerHTML=FICHES_PROC.map(f=>`
    <div class="accordion-item" onclick="this.classList.toggle('open')" data-search="${(f.title+' '+f.body).toLowerCase()}">
      <div class="accordion-head"><div class="accordion-title">${f.title}</div><div class="accordion-arrow">▶</div></div>
      <div class="accordion-body">${f.body}</div>
    </div>`).join('');

  // oral
  $('oralContent').innerHTML=ORAL_DATA.map((o,i)=>`
    <div class="accordion-item" onclick="this.classList.toggle('open')" data-search="${(o.q+' '+o.a).toLowerCase()}">
      <div class="accordion-head"><div class="accordion-title">❓ ${o.q}</div><div class="accordion-arrow">▶</div></div>
      <div class="accordion-body">${o.a}</div>
    </div>`).join('');
}

function switchFicheMode(mode,btn){
  ficheMode=mode;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  $('infractionsContent').classList.toggle('hidden',mode!=='infractions');
  $('fichesContent').classList.toggle('hidden',mode!=='fiches');
  $('oralContent').classList.toggle('hidden',mode!=='oral');
  filterFiches();
}

function filterFiches(){
  const q=$('ficheSearch').value.toLowerCase().trim();
  const gridId=ficheMode==='infractions'?'infractionsContent':ficheMode==='fiches'?'fichesContent':'oralContent';
  const items=[...$( gridId).querySelectorAll('.accordion-item')];
  items.forEach(el=>{
    const match=!q||el.dataset.search.includes(q);
    el.style.display=match?'':'none';
  });
}

// ══════════════════════════════════════════════════
//  BUILD SCORES TAB
// ══════════════════════════════════════════════════
function buildProTips(){
  const block=$('proTipsBlock');
  const tip=PRO_TIPS[Math.floor(Math.random()*PRO_TIPS.length)];
  block.innerHTML=`<div class="pro-tip" style="margin-bottom:16px"><div class="pro-tip-icon">${tip.icon}</div><div><div class="pro-tip-label">Conseil du Pro</div><div class="pro-tip-text">${tip.text}</div></div></div>`;
}

function buildDailyTip(){
  const day=new Date().getDay();
  const tip=TIPS[day%TIPS.length];
  $('dailyTip').innerHTML=`<div class="daily-tip-icon">${tip.icon}</div><div><div class="daily-tip-label">${tip.label}</div><div class="daily-tip-text">${tip.text}</div></div>`;
  // pro tip
  const pt=PRO_TIPS[Math.floor(Math.random()*PRO_TIPS.length)];
  $('proTipHome').innerHTML=`<div class="pro-tip-icon">${pt.icon}</div><div><div class="pro-tip-label">Conseil du Pro</div><div class="pro-tip-text">${pt.text}</div></div>`;
}

// ══════════════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════════════
const TAB_MAP={home:'homeSection',parcours:'parcoursSection',fiches:'fichesSection',badges:'badgesSection',scores:'scoresSection'};

function goTab(tab,el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  $(TAB_MAP[tab])?.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));
  (el||document.querySelector(`[data-tab="${tab}"]`))?.classList.add('active');
  if(tab==='badges')buildBadges();
  if(tab==='parcours')buildLevels();
  if(tab==='scores'){updateUI();buildProTips()}
  updateUI();
}

