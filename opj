//  INIT
// ══════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  updateStreak();
  updateUI();
  buildFiches();
  buildDailyTip();
  checkBadges();
  buildLevels();
});
</script>

