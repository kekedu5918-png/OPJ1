═══════════════════════════════════════ */
.badges-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:12px;padding-top:4px}
.badge-item{
background:var(–ink2);border:2px solid var(–border);
border-radius:var(–r16);padding:16px 8px;
text-align:center;transition:all .25s;
cursor:default;
}
.badge-item.earned{border-color:var(–border2);background:var(–gold-dim)}
.badge-item.earned:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(240,180,41,.2)}
.badge-icon{font-size:2rem;margin-bottom:6px;display:block;transition:transform .3s}
.badge-item.earned:hover .badge-icon{animation:bounce 1s ease-in-out infinite}
.badge-item:not(.earned){opacity:.35;filter:grayscale(1)}
.badge-name{font-size:.72rem;font-weight:700;color:var(–white)}
.badge-desc{font-size:.65rem;color:var(–silver);margin-top:3px;line-height:1.4}
.badge-lock{font-size:.75rem;color:var(–silver);margin-top:4px;opacity:.5}
.section-subtitle{font-size:.88rem;color:var(–silver);margin-bottom:16px}

