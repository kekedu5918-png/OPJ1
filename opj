// ══════════════════════════════════════════════════
//  UI UPDATE
// ══════════════════════════════════════════════════
function updateUI(){
  const lvDef=getLevelDef(S.xp);
  const range=getLevelXPRange(S.xp);
  const pct=range.progress*100;
  const acc=S.totalAnswered>0?Math.round(S.totalCorrect/S.totalAnswered*100):null;

  // topbar
  $('topXP').textContent=S.xp;
  $('topStreak').textContent=S.streak;
  $('topHearts').innerHTML=[...Array(S.maxHearts)].map((_,i)=>`<span class="heart ${i<S.hearts?'':'empty'}">❤️</span>`).join('');

  // hero
  $('heroLevel').textContent=lvDef.lvl;
  $('heroLevelName').textContent=lvDef.name;
  $('heroRankName').textContent=lvDef.rank;
  $('heroXpFill').style.width=pct+'%';
  $('heroXpCurrent').textContent=S.xp-range.cur;
  $('heroXpNext').textContent=range.next<999999?range.next-range.cur:'MAX';
  $('hTotalXP').textContent=S.xp;
  $('hStreak').textContent=S.streak;
  $('hAccuracy').textContent=acc!==null?acc+'%':'—';

  // scores tab
  $('scXP').textContent=S.xp;
  $('scLevel').textContent=lvDef.lvl;
  $('scStreak').textContent=S.streak;
  $('scAccuracy').textContent=acc!==null?acc+'%':'—';
  $('scLevelBar').style.width=pct+'%';
  $('scLevelPct').textContent=Math.round(pct)+'%';
  $('scoreRankBadge').textContent=lvDef.badge;
  $('scoreRankName').textContent=lvDef.name;
  $('scoreRankSub').textContent='Niveau '+lvDef.lvl+' — '+lvDef.rank;
}

// ══════════════════════════════════════════════════
//  BUILD LEVELS PATH
// ══════════════════════════════════════════════════
function buildLevels(){
  const el=$('levelsList');
  el.innerHTML=LEVELS.map(lv=>{
    const done=S.xp>=lv.xpNeeded;
    const cur=S.level===lv.lvl&&lv.lvl<10;
    const locked=!done&&!cur;
    const prog=done?100:cur?Math.round(getLevelXPRange(S.xp).progress*100):0;
    let cls='level-item';
    if(cur)cls+=' current';else if(done)cls+=' completed';else cls+=' locked';
    return`<div class="${cls}" onclick="if(!this.classList.contains('locked')){}">
      <div class="level-badge">${lv.badge}</div>
      <div class="level-info">
        <div class="level-num">Niveau ${lv.lvl} · ${lv.rank}</div>
        <div class="level-name">${lv.name}</div>
        <div class="level-desc">${lv.desc}</div>
        ${cur?`<div class="level-progress-mini"><div class="level-progress-mini-fill" style="width:${prog}%"></div></div>`:''}
        <div class="level-pills">
          ${done?'<span class="pill pill-green">✓ Complété</span>':cur?'<span class="pill pill-gold">⚡ En cours</span>':'<span class="pill">🔒 '+lv.xpNeeded+' XP requis</span>'}
          ${done&&lv.lvl<10?'<span class="pill pill-blue">'+lv.nextXP+' XP atteints</span>':''}
        </div>
      </div>
      <div class="level-action">${locked?'🔒':cur?'▶':'✓'}</div>
    </div>`;
  }).join('');
}

