border-radius:var(–r16);padding:14px;margin-bottom:16px;
display:flex;align-items:center;gap:12px;
}
.result-xp-num{font-family:‘Syne’,sans-serif;font-size:1.8rem;font-weight:800;color:var(–gold)}
.result-xp-info .label{font-size:.78rem;font-weight:700;color:var(–gold);text-transform:uppercase;letter-spacing:.06em}
.result-xp-info .sub{font-size:.85rem;color:var(–silver2);margin-top:2px}
.result-btns{display:grid;gap:10px}

