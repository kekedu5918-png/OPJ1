let QZ={pool:[],idx:0,score:0,hearts:5,mode:'general',answers:[],noHeartLoss:true};
const LETTERS=['A','B','C','D'];

function startModule(mode){
  let raw;
  if(mode==='general') raw=shuffle(RAW).slice(0,20);
  else if(mode==='infractions') raw=RAW.filter(r=>r.src==='CNJ Infractions');
  else if(mode==='procedure') raw=RAW.filter(r=>r.src==='Formation OPJ');
  else if(mode==='expert') raw=RAW.filter(r=>r.tag==='Expert');
  else raw=shuffle(RAW).slice(0,20);

  QZ.pool=shuffle(raw).map(buildQ);
  QZ.idx=0;QZ.score=0;QZ.hearts=S.hearts;QZ.mode=mode;QZ.answers=[];QZ.noHeartLoss=true;

  $('quizOverlay').classList.add('active');
  renderQuizQuestion();
}

function renderQuizQuestion(){
  const q=QZ.pool[QZ.idx];
  if(!q){showResults();return;}

  const pct=Math.round((QZ.idx/QZ.pool.length)*100);
  $('qProgressFill').style.width=pct+'%';
  $('qHeartsHeader').innerHTML=[...Array(S.maxHearts)].map((_,i)=>`<span class="quiz-heart ${i<QZ.hearts?'':'empty'}">❤️</span>`).join('');

  $('quizBody').innerHTML=`
    <div class="q-category">${q.tag} <span class="pill pill-blue" style="font-size:.68rem">${QZ.idx+1}/${QZ.pool.length}</span></div>
    <div class="q-text">${q.q}</div>
    <div class="options" id="opts">
      ${q.opts.map((o,i)=>`<div class="opt" id="opt${i}" onclick="pickOpt(${i})"><span class="opt-badge">${LETTERS[i]}</span>${o}</div>`).join('')}
    </div>
    <div class="expl-box" id="explBox"></div>
  `;

  const fb=$('feedbackBar');fb.className='feedback-bar';fb.innerHTML='';
  const btn=$('btnNext');btn.disabled=true;btn.textContent='Sélectionnez une réponse';
}

function pickOpt(i){
  if(QZ.answers[QZ.idx]!==undefined)return;
  QZ.answers[QZ.idx]=i;
  const q=QZ.pool[QZ.idx];
  const correct=i===q.c;
  S.totalAnswered++;

  // style options
  for(let k=0;k<q.opts.length;k++){
    const el=$(`opt${k}`);
    if(!el)continue;
    el.classList.add('disabled');
    if(k===q.c)el.classList.add('correct');
    else if(k===i&&!correct)el.classList.add('incorrect');
  }

  // explanation
  const ex=$('explBox');
  ex.innerHTML=`💡 <strong>Réponse correcte :</strong> ${q.opts[q.c]} <em style="color:var(--silver);font-size:.82rem">— ${q.src}</em>`;
  ex.classList.add('show');

  const fb=$('feedbackBar');
  if(correct){
    QZ.score++;S.totalCorrect++;S.currentCorrectStreak++;
    if(S.currentCorrectStreak>S.maxStreak)S.maxStreak=S.currentCorrectStreak;
    fb.innerHTML='✅ Excellent ! Bonne réponse';fb.className='feedback-bar correct show';
    showXPToast('+10 XP');
    addXP(10);
  } else {
    S.currentCorrectStreak=0;
    QZ.hearts=Math.max(0,QZ.hearts-1);QZ.noHeartLoss=false;
    fb.innerHTML='❌ Pas tout à fait — retenez la bonne réponse';fb.className='feedback-bar incorrect show';
    $('qHeartsHeader').innerHTML=[...Array(S.maxHearts)].map((_,ii)=>`<span class="quiz-heart ${ii<QZ.hearts?'':'empty'}">❤️</span>`).join('');
    if(QZ.hearts<=0){setTimeout(()=>{showResults(true)},1200);return}
  }

  const btn=$('btnNext');btn.disabled=false;
  btn.textContent=QZ.idx<QZ.pool.length-1?'Suivant →':'Voir les résultats 🏆';
  saveState();checkBadges();
}

function nextQ(){
  if(QZ.answers[QZ.idx]===undefined)return;
  const q=QZ.pool[QZ.idx];
  QZ.idx++;
  if(QZ.idx>=QZ.pool.length){showResults(false);return;}
  renderQuizQuestion();
}

function showResults(noHearts=false){
  $('quizOverlay').classList.remove('active');
  const total=QZ.pool.length;
  const pct=Math.round((QZ.score/total)*100);
  const xpEarned=QZ.score*10+(pct>=80?50:0)+(pct>=95?100:0);

  // update best scores
  if(QZ.mode==='infractions'&&pct>S.bestInfractions){S.bestInfractions=pct}
  if(QZ.mode==='procedure'&&pct>S.bestProcedure){S.bestProcedure=pct}
  if(QZ.noHeartLoss)S.noHeartLossQuiz++;
  S.hearts=S.maxHearts; // restore hearts
  updateStreak();
  addXP(xpEarned);
  saveState();checkBadges();

  $('rPct').textContent=pct+'%';
  $('rCorrect').textContent=QZ.score;
  $('rWrong').textContent=total-QZ.score;
  $('rXPStat').textContent='+'+xpEarned;
  $('rXP').textContent='+'+xpEarned+' XP';
  $('rXPSub').textContent=pct>=80?'Bonus perfection inclus ! 🔥':'Atteignez 80% pour le bonus !';

  let msg='',sub='';
  if(noHearts){msg='💔 Plus de cœurs !';sub='Vous avez épuisé vos cœurs. Réessayez !'}
  else if(pct>=95){msg='🏆 Performance légendaire !';sub='Vous êtes prêt pour le vrai concours.'}
  else if(pct>=80){msg='🔥 Excellent niveau !';sub='Continuez sur cette lancée !'}
  else if(pct>=65){msg='👍 Bon travail !';sub='Révisez les erreurs pour progresser.'}
  else if(pct>=50){msg='💪 En bonne voie !';sub='Retour sur les fiches conseillé.'}
  else{msg='📚 Il faut retravailler !';sub='Commencez par les fiches de base.'}
  $('rMsg').textContent=msg;$('rSub').textContent=sub;

  $('resultsScreen').classList.add('active');
  updateUI();
}

function retryQuiz(){
  $('resultsScreen').classList.remove('active');
  startModule(QZ.mode);
}

function closeResults(){
  $('resultsScreen').classList.remove('active');
  goTab('home');
  updateUI();
}

function closeQuiz(){
  $('quizOverlay').classList.remove('active');
  S.hearts=S.maxHearts;saveState();
}

function showXPToast(text){
  const t=$('xpToast');t.textContent=text;t.style.display='block';
  clearTimeout(t._to);t._to=setTimeout(()=>{t.style.display='none'},1500);
}

