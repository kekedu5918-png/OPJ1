.result-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:20px 0}
.result-stat{background:var(–ink2);border:1px solid var(–border);border-radius:var(–r12);padding:14px 8px;text-align:center}
.result-stat .n{font-family:‘Syne’,sans-serif;font-size:1.6rem;font-weight:800}
.result-stat .l{font-size:.7rem;color:var(–silver);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:2px}
.result-stat.c .n{color:var(–green)}
.result-stat.w .n{color:var(–red)}
.result-stat.x .n{color:var(–gold)}
.result-xp-earned{
