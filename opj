<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OPJ Élite — Concours Police Judiciaire</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   DESIGN SYSTEM
═══════════════════════════════════════ */
:root{
  --ink:#08111f;--ink2:#0f1e33;--ink3:#162540;--ink4:#1e3052;--ink5:#243a5e;
  --gold:#f0b429;--gold2:#ffd369;--gold-dim:rgba(240,180,41,.12);--gold-border:rgba(240,180,41,.25);
  --blue:#3d8ef0;--blue2:#60a5fa;--blue-dim:rgba(61,142,240,.12);
  --green:#22d3a0;--green-dim:rgba(34,211,160,.12);
  --red:#f05c7a;--red-dim:rgba(240,92,122,.12);
  --purple:#a78bfa;--purple-dim:rgba(167,139,250,.12);
  --silver:#7a9bbf;--silver2:#a8c4de;--white:#eef4ff;
  --border:rgba(100,140,190,.12);--border2:rgba(240,180,41,.2);
  --r4:4px;--r8:8px;--r12:12px;--r16:16px;--r20:20px;--r24:24px;--r32:32px;--rfull:999px;
  --shadow:0 8px 32px rgba(0,0,0,.45);--shadow2:0 2px 12px rgba(0,0,0,.3);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-tap-highlight-color:transparent}
body{
  font-family:'Plus Jakarta Sans',sans-serif;
  background:var(--ink);color:var(--white);
  min-height:100vh;overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
/* animated bg */
body::before{
  content:'';position:fixed;inset:0;
  background:radial-gradient(ellipse 70% 60% at 15% 0%,rgba(61,142,240,.07) 0%,transparent 55%),
             radial-gradient(ellipse 50% 40% at 85% 100%,rgba(240,180,41,.06) 0%,transparent 55%);
  pointer-events:none;z-index:0;
}
.wrap{max-width:860px;margin:0 auto;padding:0 14px 100px;position:relative;z-index:1}

/* ═══ TYPOGRAPHY ═══ */
.title{font-family:‘Syne’,sans-serif;font-weight:800}

/* ═══ ANIMATIONS ═══ */
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pop{0%,100%{transform:scale(1)}40%{transform:scale(1.12)}70%{transform:scale(.96)}}
@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-7px)}40%,80%{transform:translateX(7px)}}
@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes glow{0%,100%{box-shadow:0 0 12px rgba(240,180,41,.3)}50%{box-shadow:0 0 28px rgba(240,180,41,.7)}}
@keyframes heartLose{0%{transform:scale(1)}40%{transform:scale(1.3)}100%{transform:scale(1) opacity(0)}}
@keyframes levelUp{0%{opacity:0;transform:scale(.5) translateY(30px)}60%{transform:scale(1.15) translateY(-5px)}100%{opacity:1;transform:scale(1) translateY(0)}}
@keyframes confetti{0%{transform:translateY(-10px) rotate(0);opacity:1}100%{transform:translateY(80px) rotate(720deg);opacity:0}}
@keyframes slideIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}
@keyframes countUp{from{opacity:0;transform:scale(.3)}to{opacity:1;transform:scale(1)}}

.anim-fadeup{animation:fadeUp .4s cubic-bezier(.4,0,.2,1) both}
.anim-pop{animation:pop .5s ease}
.anim-shake{animation:shake .4s ease}

/* ═══ CARDS ═══ */
.card{
background:var(–ink2);border:1px solid var(–border);
border-radius:var(–r20);padding:20px;
transition:border-color .25s;
}
.card-gold{border-color:var(–border2);background:linear-gradient(135deg,var(–ink2),var(–ink3))}

/* ═══ BUTTONS ═══ */
.btn{
display:inline-flex;align-items:center;justify-content:center;gap:8px;
padding:14px 28px;border:none;border-radius:var(–rfull);
font-family:‘Plus Jakarta Sans’,sans-serif;font-size:.95rem;font-weight:700;
cursor:pointer;transition:all .2s ease;
}
.btn-gold{background:linear-gradient(135deg,var(–gold),#d4920a);color:var(–ink);box-shadow:0 4px 20px rgba(240,180,41,.3)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(240,180,41,.45)}
.btn-ghost{background:transparent;border:2px solid var(–border);color:var(–silver2)}
.btn-ghost:hover{border-color:var(–gold);color:var(–gold)}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none!important}
.btn-full{width:100%}

/* ═══ BADGE PILL ═══ */
.pill{
display:inline-flex;align-items:center;gap:5px;
padding:4px 12px;border-radius:var(–rfull);
font-size:.75rem;font-weight:700;letter-spacing:.04em;
}
.pill-gold{background:var(–gold-dim);border:1px solid var(–gold-border);color:var(–gold)}
.pill-blue{background:var(–blue-dim);border:1px solid rgba(61,142,240,.25);color:var(–blue2)}
.pill-green{background:var(–green-dim);border:1px solid rgba(34,211,160,.25);color:var(–green)}
.pill-red{background:var(–red-dim);border:1px solid rgba(240,92,122,.25);color:var(–red)}
.pill-purple{background:var(–purple-dim);border:1px solid rgba(167,139,250,.25);color:var(–purple)}

/* ═══════════════════════════════════════
TOPBAR
═══════════════════════════════════════ */
.topbar{
position:sticky;top:0;z-index:100;
background:rgba(8,17,31,.92);
backdrop-filter:blur(16px);
border-bottom:1px solid var(–border);
padding:10px 14px;
}
.topbar-inner{
max-width:860px;margin:0 auto;
display:flex;align-items:center;justify-content:space-between;gap:10px;
}
.topbar-brand{
display:flex;align-items:center;gap:8px;
font-family:‘Syne’,sans-serif;font-size:1.05rem;font-weight:800;
background:linear-gradient(135deg,var(–gold2),var(–gold));
-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.topbar-stats{display:flex;align-items:center;gap:14px}
.topbar-stat{
display:flex;align-items:center;gap:5px;
font-size:.9rem;font-weight:700;
}
.topbar-stat .icon{font-size:1.1rem}
.topbar-stat.xp{color:var(–gold)}
.topbar-stat.streak{color:#ff6b35}
.topbar-stat.hearts{color:var(–red)}
.streak-flame{animation:bounce 2s ease-in-out infinite}
.hearts-display{display:flex;gap:3px}
.heart{font-size:.95rem;transition:all .3s}
.heart.empty{opacity:.25;filter:grayscale(1)}

/* ═══════════════════════════════════════
BOTTOM NAV
═══════════════════════════════════════ */
.bottom-nav{
position:fixed;bottom:0;left:0;right:0;z-index:100;
background:rgba(8,17,31,.95);
backdrop-filter:blur(16px);
border-top:1px solid var(–border);
padding:8px 0 env(safe-area-inset-bottom);
}
.bottom-nav-inner{
max-width:860px;margin:0 auto;
display:flex;justify-content:space-around;
}
.nav-item{
display:flex;flex-direction:column;align-items:center;gap:3px;
padding:8px 16px;
border:none;background:none;cursor:pointer;
font-family:‘Plus Jakarta Sans’,sans-serif;
font-size:.7rem;font-weight:600;
color:var(–silver);border-radius:var(–r12);
transition:all .2s ease;
position:relative;
}
.nav-item:hover{color:var(–white)}
.nav-item.active{color:var(–gold)}
.nav-item .nav-icon{font-size:1.35rem;transition:transform .2s}
.nav-item.active .nav-icon{transform:scale(1.15)}
.nav-item .nav-dot{
position:absolute;top:6px;right:14px;
width:7px;height:7px;
background:var(–red);border-radius:50%;
display:none;
}

/* ═══════════════════════════════════════
SECTIONS
═══════════════════════════════════════ */
.section{display:none;padding-top:16px;animation:fadeUp .35s ease}
.section.active{display:block}

/* ═══════════════════════════════════════
HOME / DASHBOARD
═══════════════════════════════════════ */
.hero{
padding:28px 20px 24px;
background:linear-gradient(135deg,var(–ink2) 0%,var(–ink3) 100%);
border-radius:var(–r24);
border:1px solid var(–border2);
margin-bottom:16px;
position:relative;overflow:hidden;
}
.hero::after{
content:’’;position:absolute;top:-40px;right:-40px;
width:180px;height:180px;
background:radial-gradient(circle,rgba(240,180,41,.1),transparent 70%);
border-radius:50%;
}
.hero-rank{
font-size:.78rem;font-weight:700;color:var(–gold);
letter-spacing:.1em;text-transform:uppercase;
display:flex;align-items:center;gap:6px;margin-bottom:6px;
}
.hero-name{
font-family:‘Syne’,sans-serif;font-size:1.6rem;font-weight:800;
color:var(–white);margin-bottom:16px;line-height:1.2;
}
.hero-xp-track{height:8px;background:var(–ink4);border-radius:var(–rfull);overflow:hidden;margin-bottom:6px}
.hero-xp-fill{
height:100%;border-radius:var(–rfull);
background:linear-gradient(90deg,var(–gold),var(–gold2));
transition:width 1s cubic-bezier(.65,0,.35,1);
position:relative;overflow:hidden;
}
.hero-xp-fill::after{
content:’’;position:absolute;inset:0;
background:linear-gradient(90deg,transparent,rgba(255,255,255,.4),transparent);
animation:shimmer 2s infinite;
}
.hero-xp-label{font-size:.8rem;color:var(–silver);font-weight:600}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:18px}
.hero-stat{
background:rgba(15,30,51,.6);
border:1px solid var(–border);border-radius:var(–r12);
padding:12px 8px;text-align:center;
}
.hero-stat-num{font-family:‘Syne’,sans-serif;font-size:1.5rem;font-weight:800;color:var(–gold)}
.hero-stat-lbl{font-size:.7rem;color:var(–silver);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:2px}

/* MODULES */
.modules-header{
display:flex;justify-content:space-between;align-items:center;
margin:20px 0 12px;
}
.modules-title{font-family:‘Syne’,sans-serif;font-size:1.1rem;font-weight:800;color:var(–white)}
.modules-sub{font-size:.8rem;color:var(–silver)}
.module-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
@media(min-width:540px){.module-grid{grid-template-columns:repeat(4,1fr)}}
.module-card{
background:var(–ink2);border:2px solid var(–border);
border-radius:var(–r16);padding:16px 12px;
text-align:center;cursor:pointer;
transition:all .25s cubic-bezier(.4,0,.2,1);
position:relative;overflow:hidden;
}
.module-card::before{
content:’’;position:absolute;inset:0;opacity:0;
transition:opacity .3s;
}
.module-card:hover{transform:translateY(-4px);box-shadow:var(–shadow)}
.module-card.locked{opacity:.45;cursor:default;filter:grayscale(.8)}
.module-card .m-icon{font-size:2rem;margin-bottom:8px;display:block;transition:transform .3s}
.module-card:hover .m-icon{transform:scale(1.15) rotate(-5deg)}
.module-card .m-name{font-size:.82rem;font-weight:700;color:var(–white)}
.module-card .m-count{font-size:.72rem;color:var(–silver);margin-top:3px}
.module-card .m-lock{position:absolute;top:8px;right:8px;font-size:.85rem;opacity:.6}
/* module colors */
.module-card.c-blue{border-color:rgba(61,142,240,.25)}
.module-card.c-blue::before{background:var(–blue-dim)}
.module-card.c-blue:hover{border-color:var(–blue2)}
.module-card.c-blue:hover::before{opacity:1}
.module-card.c-gold{border-color:var(–border2)}
.module-card.c-gold::before{background:var(–gold-dim)}
.module-card.c-gold:hover{border-color:var(–gold)}
.module-card.c-gold:hover::before{opacity:1}
.module-card.c-green{border-color:rgba(34,211,160,.2)}
.module-card.c-green::before{background:var(–green-dim)}
.module-card.c-green:hover{border-color:var(–green)}
.module-card.c-green:hover::before{opacity:1}
.module-card.c-purple{border-color:rgba(167,139,250,.2)}
.module-card.c-purple::before{background:var(–purple-dim)}
.module-card.c-purple:hover{border-color:var(–purple)}
.module-card.c-purple:hover::before{opacity:1}

/* daily tip */
.daily-tip{
background:var(–blue-dim);border:1px solid rgba(61,142,240,.2);
border-radius:var(–r16);padding:16px;margin-bottom:16px;
display:flex;align-items:flex-start;gap:12px;
animation:slideIn .4s ease;
}
.daily-tip-icon{font-size:1.5rem;flex-shrink:0}
.daily-tip-label{font-size:.72rem;font-weight:700;color:var(–blue2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.daily-tip-text{font-size:.88rem;color:var(–silver2);line-height:1.6}
.daily-tip-text strong{color:var(–white)}

/* ═══════════════════════════════════════
LEVELS / PARCOURS
═══════════════════════════════════════ */
.levels-path{display:grid;gap:12px;padding-top:4px}
.level-item{
display:flex;align-items:center;gap:14px;
padding:14px 16px;
background:var(–ink2);border:2px solid var(–border);
border-radius:var(–r16);cursor:pointer;
transition:all .25s ease;
position:relative;
}
.level-item:hover:not(.locked){transform:translateX(6px);border-color:var(–border2)}
.level-item.current{border-color:var(–gold);background:var(–gold-dim);animation:glow 3s ease-in-out infinite}
.level-item.completed{border-color:rgba(34,211,160,.3);background:var(–green-dim)}
.level-item.locked{opacity:.4;cursor:default}
.level-badge{
width:52px;height:52px;border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:1.5rem;flex-shrink:0;
background:var(–ink3);border:2px solid var(–border);
transition:transform .3s;
}
.level-item.current .level-badge{background:var(–gold-dim);border-color:var(–gold);transform:scale(1.1)}
.level-item.completed .level-badge{background:var(–green-dim);border-color:var(–green)}
.level-item:hover:not(.locked) .level-badge{transform:scale(1.08) rotate(5deg)}
.level-info{flex:1;min-width:0}
.level-num{font-size:.7rem;font-weight:700;color:var(–silver);text-transform:uppercase;letter-spacing:.08em}
.level-name{font-family:‘Syne’,sans-serif;font-size:1rem;font-weight:800;color:var(–white);margin:2px 0 4px}
.level-desc{font-size:.78rem;color:var(–silver);line-height:1.4}
.level-pills{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
.level-action{flex-shrink:0;font-size:1.1rem;color:var(–silver);transition:transform .3s}
.level-item:hover:not(.locked) .level-action{transform:translateX(4px);color:var(–gold)}
.level-progress-mini{height:4px;background:var(–ink4);border-radius:var(–rfull);overflow:hidden;margin-top:6px}
.level-progress-mini-fill{height:100%;background:linear-gradient(90deg,var(–gold),var(–gold2));border-radius:var(–rfull)}

/* ═══════════════════════════════════════
QUIZ ENGINE
═══════════════════════════════════════ */
.quiz-overlay{
display:none;
position:fixed;inset:0;z-index:200;
background:var(–ink);
flex-direction:column;
overflow-y:auto;
}
.quiz-overlay.active{display:flex}

.quiz-header{
padding:14px 16px;
display:flex;align-items:center;justify-content:space-between;gap:12px;
background:var(–ink2);border-bottom:1px solid var(–border);
position:sticky;top:0;z-index:10;
}
.quiz-close{
background:var(–ink3);border:1px solid var(–border);
border-radius:50%;width:36px;height:36px;
display:flex;align-items:center;justify-content:center;
cursor:pointer;font-size:1rem;color:var(–silver);
transition:all .2s;
}
.quiz-close:hover{background:var(–red-dim);border-color:var(–red);color:var(–red)}
.quiz-progress-track{flex:1;height:8px;background:var(–ink4);border-radius:var(–rfull);overflow:hidden}
.quiz-progress-fill{height:100%;background:linear-gradient(90deg,var(–blue),var(–blue2));border-radius:var(–rfull);transition:width .5s ease}
.quiz-hearts-header{display:flex;gap:4px;flex-shrink:0}
.quiz-heart{font-size:1.1rem;transition:all .3s}
.quiz-heart.empty{opacity:.2;filter:grayscale(1)}

.quiz-body{flex:1;padding:20px 16px;max-width:700px;margin:0 auto;width:100%}
.q-category{font-size:.75rem;font-weight:700;color:var(–blue2);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.q-num{font-size:.8rem;color:var(–silver);font-weight:600;margin-bottom:10px}
.q-text{
font-family:‘Syne’,sans-serif;font-size:clamp(1.1rem,2.8vw,1.45rem);
font-weight:800;color:var(–white);line-height:1.4;margin-bottom:24px;
}
.options{display:grid;gap:10px;margin-bottom:16px}
.opt{
padding:15px 18px;
background:var(–ink3);border:2px solid var(–border);
border-radius:var(–r16);cursor:pointer;
transition:all .2s cubic-bezier(.4,0,.2,1);
font-size:.97rem;font-weight:500;color:var(–white);
display:flex;align-items:center;gap:12px;line-height:1.45;
text-align:left;
}
.opt-badge{
min-width:30px;height:30px;border-radius:50%;
background:var(–ink4);border:1px solid var(–border);
display:flex;align-items:center;justify-content:center;
font-size:.8rem;font-weight:800;color:var(–silver);
transition:all .2s;flex-shrink:0;
}
.opt:hover:not(.disabled){border-color:var(–blue2);background:var(–blue-dim);transform:translateX(5px)}
.opt:hover:not(.disabled) .opt-badge{background:var(–blue-dim);border-color:var(–blue2);color:var(–blue2)}
.opt.correct{border-color:var(–green);background:var(–green-dim);animation:pop .5s ease}
.opt.correct .opt-badge{background:var(–green);color:var(–ink);border-color:var(–green)}
.opt.incorrect{border-color:var(–red);background:var(–red-dim);animation:shake .4s ease}
.opt.incorrect .opt-badge{background:var(–red);color:#fff;border-color:var(–red)}
.opt.disabled{pointer-events:none}
.opt.disabled:not(.correct):not(.incorrect){opacity:.4}

.expl-box{
padding:14px 16px;
background:var(–ink3);border-radius:var(–r12);
border-left:3px solid var(–gold);
font-size:.88rem;color:var(–silver2);line-height:1.7;
display:none;animation:fadeUp .3s ease;
margin-bottom:16px;
}
.expl-box.show{display:block}
.expl-box strong{color:var(–white)}

.quiz-footer{
padding:14px 16px;
background:var(–ink2);border-top:1px solid var(–border);
position:sticky;bottom:0;
}
.quiz-footer-inner{max-width:700px;margin:0 auto}

/* answer feedback */
.feedback-bar{
padding:12px 16px;border-radius:var(–r12);
display:none;margin-bottom:10px;
font-weight:700;font-size:.95rem;
align-items:center;gap:10px;
animation:fadeUp .3s ease;
}
.feedback-bar.show{display:flex}
.feedback-bar.correct{background:var(–green-dim);border:1px solid rgba(34,211,160,.3);color:var(–green)}
.feedback-bar.incorrect{background:var(–red-dim);border:1px solid rgba(240,92,122,.3);color:var(–red)}

/* xp toast */
.xp-toast{
position:fixed;top:70px;right:16px;z-index:300;
background:var(–gold-dim);border:1px solid var(–gold-border);
border-radius:var(–rfull);padding:8px 16px;
font-weight:800;font-size:.9rem;color:var(–gold);
pointer-events:none;
animation:countUp .4s cubic-bezier(.34,1.56,.64,1) both;
display:none;
}

/* ═══════════════════════════════════════
LEVEL UP OVERLAY
═══════════════════════════════════════ */
.levelup-overlay{
display:none;
position:fixed;inset:0;z-index:500;
background:rgba(8,17,31,.97);
align-items:center;justify-content:center;
flex-direction:column;text-align:center;padding:32px;
}
.levelup-overlay.active{display:flex}
.levelup-badge{font-size:6rem;animation:levelUp .6s cubic-bezier(.34,1.56,.64,1)}
.levelup-title{font-family:‘Syne’,sans-serif;font-size:2.5rem;font-weight:800;color:var(–gold);margin:16px 0 8px}
.levelup-sub{font-size:1.1rem;color:var(–silver);margin-bottom:32px}
.confetti-container{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.confetti-piece{
position:absolute;width:8px;height:8px;
border-radius:2px;animation:confetti 2.5s ease-out both;
}

/* ═══════════════════════════════════════
RESULTS SCREEN
═══════════════════════════════════════ */
.results-screen{
display:none;flex-direction:column;
background:var(–ink);min-height:100vh;
padding:20px 16px;
}
.results-screen.active{display:flex}
.results-inner{max-width:700px;margin:0 auto;width:100%}
.result-header{text-align:center;padding:32px 0}
.result-score-ring{
width:130px;height:130px;border-radius:50%;
border:4px solid var(–gold);
display:flex;flex-direction:column;align-items:center;justify-content:center;
margin:0 auto 16px;background:var(–gold-dim);
animation:levelUp .5s cubic-bezier(.34,1.56,.64,1);
}
.result-pct{font-family:‘Syne’,sans-serif;font-size:2.2rem;font-weight:800;color:var(–gold)}
.result-label{font-size:.75rem;color:var(–silver);font-weight:600}
