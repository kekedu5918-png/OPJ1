FICHES & INFRACTIONS
═══════════════════════════════════════ */
.search-bar{
width:100%;padding:12px 18px;
background:var(–ink2);border:1px solid var(–border);
border-radius:var(–rfull);color:var(–white);
font-family:‘Plus Jakarta Sans’,sans-serif;font-size:.95rem;
outline:none;margin-bottom:14px;transition:all .2s;
}
.search-bar::placeholder{color:var(–silver)}
.search-bar:focus{border-color:var(–border2);box-shadow:0 0 0 3px var(–gold-dim)}

.accordion-list{display:grid;gap:10px}
.accordion-item{
background:var(–ink2);border:1px solid var(–border);
border-radius:var(–r16);overflow:hidden;cursor:pointer;
transition:all .2s ease;
}
.accordion-item:hover{border-color:var(–border2);transform:translateX(4px)}
.accordion-head{
