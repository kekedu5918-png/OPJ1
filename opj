const DEFAULT_STATE={
  xp:0,level:1,streak:0,hearts:5,maxHearts:5,
  lastPlayDate:null,lastStreakDate:null,
  totalAnswered:0,totalCorrect:0,maxStreak:0,
  currentCorrectStreak:0,earnedBadges:[],
  bestInfractions:0,bestProcedure:0,noHeartLossQuiz:0,
};
let S=JSON.parse(localStorage.getItem('opj_state_v2')||'null')||{...DEFAULT_STATE};

function saveState(){localStorage.setItem('opj_state_v2',JSON.stringify(S))}
function resetAll(){localStorage.removeItem('opj_state_v2');S={...DEFAULT_STATE};saveState();location.reload()}

function getLevelDef(xp){
  let l=LEVELS[0];
  for(const lv of LEVELS){if(xp>=lv.xpNeeded)l=lv}
  return l;
}
function getLevelByNum(n){return LEVELS.find(l=>l.lvl===n)||LEVELS[0]}
function getLevelXPRange(xp){
  const cur=getLevelDef(xp);
  return{cur:cur.xpNeeded,next:cur.nextXP,progress:cur.nextXP<999999?(xp-cur.xpNeeded)/(cur.nextXP-cur.xpNeeded):1};
}

function addXP(amount){
  const oldLvl=getLevelDef(S.xp).lvl;
  S.xp+=amount;
  const newLvl=getLevelDef(S.xp);
  S.level=newLvl.lvl;
  saveState();
  if(newLvl.lvl>oldLvl) triggerLevelUp(newLvl);
}

function updateStreak(){
  const today=new Date().toDateString();
  if(S.lastStreakDate===today)return;
  const yesterday=new Date(Date.now()-864e5).toDateString();
  if(S.lastStreakDate===yesterday){S.streak++;} else {S.streak=1;}
  S.lastStreakDate=today;
  saveState();
}

